{
  "schema_version": "monarch-os-kernel-hardening-baseline/v1",
  "talos_version": "v1.13.0",
  "arch": "amd64",
  "rootfs": {
    "requires_read_only_root": true,
    "requires_immutable_base_mount": true,
    "immutable_filesystems": ["squashfs", "erofs"],
    "requires_dm_verity_kernel_support": true,
    "dm_verity_active_evidence_required": false,
    "dm_verity_root_hash_evidence": [
      "kernel-cmdline root_hash, roothash, usrhash, or dm-mod.create verity table",
      "device-mapper root device sysfs name/uuid when exposed by the booted image"
    ]
  },
  "required_kernel_options": {
    "enabled": [
      "CONFIG_SQUASHFS",
      "CONFIG_BLK_DEV_DM",
      "CONFIG_DM_VERITY"
    ],
    "disabled_or_absent": [
      "CONFIG_CRYPTO_USER_API_AEAD",
      "CONFIG_CRYPTO_USER_API_SKCIPHER",
      "CONFIG_CRYPTO_USER_API_HASH",
      "CONFIG_CRYPTO_USER_API_RNG",
      "CONFIG_KVM",
      "CONFIG_BT",
      "CONFIG_WLAN",
      "CONFIG_SOUND"
    ]
  },
  "proc_evidence": [
    "/proc/config.gz",
    "/proc/cmdline",
    "/proc/mounts",
    "/proc/modules",
    "/proc/filesystems"
  ]
}
