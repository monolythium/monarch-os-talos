{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/monarch-incident-response.v1.json",
  "title": "Monarch Incident Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident",
    "chain",
    "response",
    "runbook",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "monarch-incident-response/v1"
    },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "severity", "status", "opened_at", "summary"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "pcr-drift",
            "substrate-proof-failure",
            "talos-ca-mismatch",
            "certificate-expiry",
            "protocore-rpc-down",
            "ext-protocore-crash-loop",
            "network-partition",
            "cryptographic-break",
            "bridge-exploit",
            "adversarial-fork",
            "key-share-compromise",
            "release-provenance-failure"
          ]
        },
        "severity": {
          "enum": ["low", "medium", "high", "critical"]
        },
        "status": {
          "enum": ["detected", "triaged", "contained", "mitigated", "postmortem"]
        },
        "opened_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id"],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "chain_id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "anchor_height": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "dag_round": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "scope", "operator_instructions"],
      "properties": {
        "action": {
          "enum": [
            "observe",
            "isolate-node",
            "stop-signing",
            "rotate-certs",
            "rotate-key-share",
            "pause-bridge-route",
            "freeze-admission",
            "emergency-key-rotation",
            "rollback-bridge",
            "publish-replacement-release",
            "recover-node"
          ]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope_type"],
          "properties": {
            "scope_type": {
              "enum": ["node", "cluster", "release", "bridge-route", "global"]
            },
            "node_id": {
              "type": "string"
            },
            "cluster_id": {
              "type": ["string", "integer"],
              "pattern": "^[0-9]+$"
            },
            "release_metadata_sha256": {
              "type": "string",
              "pattern": "^(0x)?[0-9a-fA-F]{64}$"
            },
            "bridge_route_id": {
              "type": "string"
            }
          }
        },
        "operator_instructions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "runbook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "schema_hash",
        "signed_payload_hash",
        "signature_scheme",
        "signature"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "schema_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "signed_payload_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "signature_scheme": {
          "enum": ["ML-DSA-65", "SLH-DSA"]
        },
        "signature": {
          "type": "string",
          "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,})$"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_metadata_sha256", "files"],
      "properties": {
        "release_metadata_sha256": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "pcr_quote_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "source", "sha256"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "pattern": "^(0x)?[0-9a-fA-F]{64}$"
              }
            }
          }
        }
      }
    },
    "foundation_authorization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threshold": {
          "type": "integer",
          "minimum": 2
        },
        "signer_set_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "ratification_deadline": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "signatures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "signer_id",
              "public_key_hash",
              "signature_scheme",
              "signed_payload_hash",
              "signature"
            ],
            "properties": {
              "signer_id": {
                "type": "string",
                "minLength": 1
              },
              "public_key_hash": {
                "type": "string",
                "pattern": "^(0x)?[0-9a-fA-F]{64}$"
              },
              "signature_scheme": {
                "enum": ["ML-DSA-65", "SLH-DSA"]
              },
              "signed_payload_hash": {
                "type": "string",
                "pattern": "^(0x)?[0-9a-fA-F]{64}$"
              },
              "signature": {
                "type": "string",
                "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,})$"
              }
            }
          }
        }
      }
    },
    "on_chain_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tx_hash",
        "dag_round",
        "quorum_certificate_hash",
        "executor_contract",
        "executor_method",
        "function_selector",
        "calldata_hash"
      ],
      "properties": {
        "tx_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "dag_round": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "quorum_certificate_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "executor_contract": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "executor_method": {
          "enum": [
            "freezeAdmission",
            "pauseBridgeRoute",
            "rollbackBridge",
            "emergencyKeyRotation"
          ]
        },
        "function_selector": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{8}$"
        },
        "calldata_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        }
      }
    }
  }
}
