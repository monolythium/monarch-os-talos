{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/protocore-tpm-sealing-evidence.v1.json",
  "title": "Monarch Protocore TPM Sealing Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chain",
    "cluster",
    "operator",
    "release",
    "tpm",
    "dkg",
    "sealed_share",
    "sealing",
    "approvals"
  ],
  "properties": {
    "schema_version": {
      "const": "monarch-protocore-tpm-sealing-evidence/v1"
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "chain_id": { "type": ["string", "integer"], "pattern": "^[0-9]+$" }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dkg_epoch"],
      "properties": {
        "id": { "type": ["string", "integer"], "pattern": "^[0-9]+$" },
        "dkg_epoch": { "type": ["string", "integer"], "pattern": "^[0-9]+$" }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "address", "position", "tpm_mode"],
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 9 },
        "address": { "type": "string", "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$" },
        "position": { "type": "string", "enum": ["active", "standby"] },
        "tpm_mode": { "type": "string", "enum": ["hardware-tpm2", "vtpm-testnet"] }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_sha256", "protocore_digest"],
      "properties": {
        "metadata_sha256": { "$ref": "#/$defs/hash32" },
        "protocore_digest": { "$ref": "#/$defs/hash32" }
      }
    },
    "tpm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "pcr_bank",
        "pcrs",
        "pcr_values",
        "quote_file",
        "event_log_file",
        "quote_sha256",
        "event_log_sha256",
        "quote_nonce",
        "sealed_share_policy_hash"
      ],
      "properties": {
        "mode": { "type": "string", "enum": ["hardware-tpm2", "vtpm-testnet"] },
        "pcr_bank": { "type": "string", "enum": ["sha256", "sha384"] },
        "pcrs": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "integer", "minimum": 0, "maximum": 23 }
        },
        "pcr_values": {
          "type": "object",
          "additionalProperties": false,
          "required": ["0", "2", "4", "7"],
          "patternProperties": {
            "^[0-9]+$": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{64}([0-9a-fA-F]{32})?$"
            }
          }
        },
        "quote_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
        "event_log_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
        "quote_sha256": { "$ref": "#/$defs/hash32" },
        "event_log_sha256": { "$ref": "#/$defs/hash32" },
        "quote_nonce": { "$ref": "#/$defs/hash32" },
        "sealed_share_policy_hash": { "$ref": "#/$defs/hash32" },
        "quote_verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tool",
            "ak_public_file",
            "quote_signature_file",
            "pcr_digest_file",
            "ak_public_sha256",
            "quote_signature_sha256",
            "pcr_digest_sha256"
          ],
          "properties": {
            "tool": { "const": "tpm2_checkquote" },
            "ak_public_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
            "quote_signature_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
            "pcr_digest_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
            "ak_public_sha256": { "$ref": "#/$defs/hash32" },
            "quote_signature_sha256": { "$ref": "#/$defs/hash32" },
            "pcr_digest_sha256": { "$ref": "#/$defs/hash32" }
          }
        }
      }
    },
    "dkg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transcript_file",
        "transcript_sha256",
        "encrypted_share_bundle_hash",
        "group_public_key_hex"
      ],
      "properties": {
        "transcript_file": { "type": "string", "pattern": "^/var/lib/protocore/secrets/.+" },
        "transcript_sha256": { "$ref": "#/$defs/hash32" },
        "encrypted_share_bundle_hash": { "$ref": "#/$defs/hash32" },
        "group_public_key_hex": { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]{96}$" }
      }
    },
    "sealed_share": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "sha256",
        "plaintext_share_hash",
        "sealed_to_tpm"
      ],
      "properties": {
        "file": { "type": "string", "pattern": "^/var/lib/protocore/secrets/.+" },
        "sha256": { "$ref": "#/$defs/hash32" },
        "plaintext_share_hash": { "$ref": "#/$defs/hash32" },
        "sealed_to_tpm": { "const": true }
      }
    },
    "sealing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain",
        "tool_version",
        "command_log_file",
        "command_log_sha256",
        "public_blob_file",
        "public_blob_sha256",
        "private_blob_file",
        "private_blob_sha256",
        "context_file",
        "context_sha256",
        "unseal_validation"
      ],
      "properties": {
        "toolchain": { "const": "tpm2-tools" },
        "tool_version": { "type": "string", "minLength": 1 },
        "command_log_file": { "type": "string", "pattern": "^/var/lib/protocore/attestation/.+" },
        "command_log_sha256": { "$ref": "#/$defs/hash32" },
        "public_blob_file": { "type": "string", "pattern": "^/var/lib/protocore/secrets/.+" },
        "public_blob_sha256": { "$ref": "#/$defs/hash32" },
        "private_blob_file": { "type": "string", "pattern": "^/var/lib/protocore/secrets/.+" },
        "private_blob_sha256": { "$ref": "#/$defs/hash32" },
        "context_file": { "type": "string", "pattern": "^/var/lib/protocore/secrets/.+" },
        "context_sha256": { "$ref": "#/$defs/hash32" },
        "unseal_validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["performed", "pcr_policy_digest", "plaintext_share_hash"],
          "properties": {
            "performed": { "const": true },
            "pcr_policy_digest": { "$ref": "#/$defs/hash32" },
            "plaintext_share_hash": { "$ref": "#/$defs/hash32" }
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operator_index",
          "address",
          "signature_scheme",
          "signed_payload_hash",
          "signature"
        ],
        "properties": {
          "operator_index": { "type": "integer", "minimum": 0, "maximum": 9 },
          "address": { "type": "string", "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$" },
          "signature_scheme": { "type": "string", "enum": ["ML-DSA-65", "SLH-DSA"] },
          "signed_payload_hash": { "$ref": "#/$defs/hash32" },
          "signature": { "type": "string", "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,})$" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operator": {
            "properties": {
              "tpm_mode": { "const": "hardware-tpm2" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "tpm": {
            "required": ["quote_verification"]
          }
        }
      }
    }
  ],
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^(0x)?[0-9a-fA-F]{64}$"
    }
  }
}
