{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/monarch-operator-audit-trail.v1.json",
  "title": "Monarch Operator Audit Trail",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit",
    "chain",
    "actor",
    "release",
    "subject",
    "intent",
    "evidence",
    "approvals"
  ],
  "properties": {
    "schema_version": { "const": "monarch-operator-audit-trail/v1" },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "created_at", "action", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "action": {
          "type": "string",
          "enum": [
            "enrollment",
            "tpm-sealing",
            "operator-key-rotation",
            "certificate-rotation",
            "backup",
            "restore",
            "disaster-recovery",
            "incident-response",
            "freeze-admission",
            "kill-switch-freeze",
            "upgrade",
            "rollback",
            "desktop-operation",
            "chat-e2e",
            "release-promotion"
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "previous_audit_hash": { "$ref": "#/$defs/hash32" }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "chain_id": { "type": ["string", "integer"], "pattern": "^[0-9]+$" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "address"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["operator", "foundation", "desktop", "os-ci", "automation"]
        },
        "address": {
          "type": "string",
          "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40}|ci:[A-Za-z0-9_.:-]+)$"
        },
        "operator_index": { "type": "integer", "minimum": 0, "maximum": 9 },
        "cluster_id": { "type": ["string", "integer"], "pattern": "^[0-9]+$" }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_sha256", "protocore_digest"],
      "properties": {
        "metadata_sha256": { "$ref": "#/$defs/hash32" },
        "protocore_digest": { "$ref": "#/$defs/hash32" }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "enrollment",
            "tpm-sealing-evidence",
            "incident-response",
            "disaster-recovery",
            "talos-certificate-rotation",
            "offline-backup",
            "offline-restore",
            "desktop-operation",
            "desktop-e2e",
            "release"
          ]
        },
        "id": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/hash32" }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "expected_state_hash", "risk", "diff_vs_intent_hash"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "expected_state_hash": { "$ref": "#/$defs/hash32" },
        "diff_vs_intent_hash": { "$ref": "#/$defs/hash32" },
        "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "requires_approval": { "type": "boolean" }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "type", "sha256"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": [
              "manifest",
              "receipt",
              "tx",
              "file",
              "desktop-e2e",
              "smoke-qemu",
              "talos-read",
              "rpc",
              "operator-note"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "schema_version": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/hash32" }
        }
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "status", "id"],
        "properties": {
          "source": { "type": "string", "enum": ["desktop", "talos", "on-chain", "ci", "operator"] },
          "status": { "type": "string", "enum": ["ok", "error"] },
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "audit_payload_schema": { "type": "string", "minLength": 1 },
          "audit_payload_hash": { "$ref": "#/$defs/hash32" },
          "tx_hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
          "dag_round": { "type": ["string", "integer"], "pattern": "^[0-9]+$" },
          "quorum_certificate_hash": { "$ref": "#/$defs/hash32" },
          "artifact_sha256": { "$ref": "#/$defs/hash32" }
        }
      }
    },
    "peer_vouches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["peer_id", "address", "signed_payload_hash", "signature"],
        "properties": {
          "peer_id": { "type": "string", "minLength": 1 },
          "address": { "type": "string", "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$" },
          "signed_payload_hash": { "$ref": "#/$defs/hash32" },
          "signature": { "$ref": "#/$defs/signature" }
        }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signer", "signer_role", "signature_scheme", "signed_payload_hash", "signature"],
        "properties": {
          "signer": { "type": "string", "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40}|ci:[A-Za-z0-9_.:-]+)$" },
          "signer_role": { "type": "string", "enum": ["operator", "foundation", "desktop", "os-ci", "automation", "peer"] },
          "signature_scheme": { "type": "string", "enum": ["ML-DSA-65", "SLH-DSA", "ci-attestation"] },
          "signed_payload_hash": { "$ref": "#/$defs/hash32" },
          "signature": { "$ref": "#/$defs/signature" }
        }
      }
    }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^(0x)?[0-9a-fA-F]{64}$"
    },
    "signature": {
      "type": "string",
      "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,}|github-attestation:[A-Za-z0-9_.:/@+-]+)$"
    }
  }
}
