{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/protocore-key-share-ceremony.v1.json",
  "title": "Monarch Protocore Key-Share Ceremony",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ceremony",
    "chain",
    "cluster",
    "operators",
    "dkg",
    "release",
    "sealed_share_outputs",
    "approvals"
  ],
  "properties": {
    "schema_version": {
      "const": "monarch-protocore-key-share-ceremony/v1"
    },
    "ceremony": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "runbook_id", "created_at", "reason"],
      "properties": {
        "type": {
          "enum": [
            "initial-dkg",
            "operator-rotation",
            "share-reseal",
            "recovery",
            "emergency-revocation"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "runbook_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id"],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "chain_id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "size",
        "threshold",
        "active_members",
        "standby_members",
        "previous_dkg_epoch",
        "next_dkg_epoch"
      ],
      "properties": {
        "id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "size": {
          "const": 10
        },
        "threshold": {
          "const": 7
        },
        "active_members": {
          "const": 7
        },
        "standby_members": {
          "const": 3
        },
        "previous_dkg_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "next_dkg_epoch": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operators": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "address",
          "position",
          "tpm_mode",
          "pcr_quote_hash",
          "pcr_event_log_hash",
          "sealed_share_policy_hash"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "address": {
            "type": "string",
            "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$"
          },
          "position": {
            "type": "string",
            "enum": ["active", "standby"]
          },
          "tpm_mode": {
            "type": "string",
            "enum": ["hardware-tpm2", "vtpm-testnet"]
          },
          "pcr_quote_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "pcr_event_log_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "sealed_share_policy_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          }
        }
      }
    },
    "dkg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threshold_scheme",
        "next_transcript_file",
        "next_transcript_hash",
        "transcript_commitment_hash",
        "participant_commitments_hash",
        "encrypted_share_bundle_hash",
        "group_public_key_hex"
      ],
      "properties": {
        "threshold_scheme": {
          "const": "Ferveo-BLS12-381"
        },
        "previous_transcript_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "next_transcript_file": {
          "type": "string",
          "pattern": "^/var/lib/protocore/secrets/.+"
        },
        "next_transcript_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "transcript_commitment_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "participant_commitments_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "encrypted_share_bundle_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "group_public_key_hex": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{96}$"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_sha256", "protocore_digest"],
      "properties": {
        "metadata_sha256": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "protocore_digest": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        }
      }
    },
    "sealed_share_outputs": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operator_index",
          "share_file",
          "sha256",
          "sealed_to_tpm",
          "tpm_mode",
          "pcr_quote_hash",
          "pcr_event_log_hash",
          "sealed_share_policy_hash",
          "dkg_transcript_hash",
          "dkg_epoch"
        ],
        "properties": {
          "operator_index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "share_file": {
            "type": "string",
            "pattern": "^/var/lib/protocore/secrets/.+"
          },
          "sha256": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "sealed_to_tpm": {
            "const": true
          },
          "tpm_mode": {
            "type": "string",
            "enum": ["hardware-tpm2", "vtpm-testnet"]
          },
          "pcr_quote_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "pcr_event_log_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "sealed_share_policy_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "dkg_transcript_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "dkg_epoch": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operator_index",
          "address",
          "signature_scheme",
          "signed_payload_hash",
          "signature"
        ],
        "properties": {
          "operator_index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "address": {
            "type": "string",
            "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$"
          },
          "signature_scheme": {
            "const": "ML-DSA-65"
          },
          "signed_payload_hash": {
            "type": "string",
            "pattern": "^(0x)?[0-9a-fA-F]{64}$"
          },
          "signature": {
            "type": "string",
            "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,})$"
          }
        }
      }
    },
    "on_chain_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry_contract": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "cluster_id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "next_dkg_epoch": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "ceremony_tx_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "attestation_tx_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "dag_round": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "quorum_certificate_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "ceremony_method": {
          "const": "submitPendingChange"
        },
        "ceremony_function_selector": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{8}$"
        },
        "ceremony_calldata_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "attestation_method": {
          "const": "attestDkgReshare"
        },
        "attestation_function_selector": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{8}$"
        },
        "attestation_calldata_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        },
        "lifecycle_payload_hash": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{64}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["chain"],
        "properties": {
          "chain": {
            "required": ["profile"],
            "properties": {
              "profile": {
                "const": "mainnet"
              }
            }
          }
        }
      },
      "then": {
        "required": ["on_chain_lifecycle"],
        "properties": {
          "on_chain_lifecycle": {
            "required": [
              "registry_contract",
              "cluster_id",
              "next_dkg_epoch",
              "ceremony_tx_hash",
              "attestation_tx_hash",
              "dag_round",
              "quorum_certificate_hash",
              "ceremony_method",
              "ceremony_function_selector",
              "ceremony_calldata_hash",
              "attestation_method",
              "attestation_function_selector",
              "attestation_calldata_hash",
              "lifecycle_payload_hash"
            ]
          }
        }
      }
    }
  ]
}
