{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/monarch-disaster-recovery.schema.json",
  "title": "Monarch Disaster Recovery Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recovery",
    "chain",
    "release",
    "node",
    "backup",
    "restore",
    "approvals"
  ],
  "properties": {
    "schema_version": {
      "const": "monarch-disaster-recovery/v1"
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "runbook_id", "opened_at"],
      "properties": {
        "id": { "type": "string", "minLength": 8 },
        "type": {
          "enum": ["resync", "offline-restore", "disk-replacement", "signing-node-reseal"]
        },
        "runbook_id": { "type": "string", "minLength": 4 },
        "opened_at": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id", "genesis_sha256"],
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "chain_id": { "type": "integer", "minimum": 1 },
        "genesis_sha256": { "$ref": "#/$defs/hash32" }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_sha256", "protocore_digest"],
      "properties": {
        "metadata_sha256": { "$ref": "#/$defs/hash32" },
        "protocore_digest": { "$ref": "#/$defs/hash32" },
        "source_release_digest": { "$ref": "#/$defs/hash32" },
        "target_release_digest": { "$ref": "#/$defs/hash32" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "node_id"],
      "properties": {
        "role": { "enum": ["archive", "operator-signing", "rpc", "bridge"] },
        "node_id": { "type": "string", "minLength": 4 },
        "operator_address": {
          "type": "string",
          "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$"
        },
        "cluster_id": { "type": "integer", "minimum": 0 },
        "operator_index": { "type": "integer", "minimum": 0, "maximum": 9 }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "protocore_service_state"],
      "properties": {
        "mode": {
          "enum": ["resync", "offline-snapshot", "stopped-protocore-archive"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "protocore_service_state": {
          "enum": ["not-applicable", "stopped", "offline"]
        },
        "hot_backup": { "type": "boolean" },
        "storage_uri": { "type": "string" },
        "snapshot_id": { "type": "string" },
        "var_lib_protocore_sha256": { "$ref": "#/$defs/hash32" },
        "manifest_sha256": { "$ref": "#/$defs/hash32" },
        "encrypted": { "type": "boolean" },
        "encryption_key_ref": { "type": "string" }
      }
    },
    "restore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_node_id",
        "restore_path",
        "service_stopped_before_restore",
        "post_restore_checks"
      ],
      "properties": {
        "target_node_id": { "type": "string", "minLength": 4 },
        "restore_path": { "const": "/var/lib/protocore" },
        "service_stopped_before_restore": { "type": "boolean" },
        "resync_from_peers": { "type": "boolean" },
        "post_restore_checks": {
          "type": "array",
          "items": {
            "enum": [
              "release-digest-match",
              "genesis-match",
              "chain-id-match",
              "protocore-rpc-healthy",
              "no-double-sign-window",
              "key-share-resealed"
            ]
          },
          "minItems": 3,
          "uniqueItems": true
        }
      }
    },
    "key_share_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ceremony_manifest_sha256",
        "sealed_share_sha256",
        "dkg_transcript_hash",
        "approval_count"
      ],
      "properties": {
        "ceremony_manifest_sha256": { "$ref": "#/$defs/hash32" },
        "sealed_share_sha256": { "$ref": "#/$defs/hash32" },
        "dkg_transcript_hash": { "$ref": "#/$defs/hash32" },
        "approval_count": { "type": "integer", "minimum": 7 }
      }
    },
    "on_chain_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tx_hash",
        "dag_round",
        "quorum_certificate_hash",
        "executor_contract",
        "executor_method",
        "operator_peer_id",
        "function_selector",
        "calldata_hash"
      ],
      "properties": {
        "tx_hash": { "$ref": "#/$defs/txHash" },
        "dag_round": { "type": "integer", "minimum": 1 },
        "quorum_certificate_hash": { "$ref": "#/$defs/hash32" },
        "executor_contract": { "$ref": "#/$defs/address" },
        "executor_method": { "const": "recoverOperatorNode" },
        "operator_peer_id": { "$ref": "#/$defs/hash32" },
        "function_selector": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{8}$"
        },
        "calldata_hash": { "$ref": "#/$defs/hash32" }
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["address", "signature_scheme", "signed_payload_hash", "signature"],
        "properties": {
          "address": {
            "type": "string",
            "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$"
          },
          "signature_scheme": { "const": "ML-DSA-65" },
          "signed_payload_hash": { "$ref": "#/$defs/hash32" },
          "signature": {
            "type": "string",
            "pattern": "^(0x[0-9a-fA-F]{128,}|[A-Za-z0-9+/=]{128,})$"
          }
        }
      }
    }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^(0x)?[0-9a-fA-F]{64}$"
    },
    "txHash": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    }
  }
}
