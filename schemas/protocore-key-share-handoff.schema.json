{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolythium.com/schemas/protocore-key-share-handoff.v1.json",
  "title": "Monarch Protocore Key-Share Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff",
    "ceremony_manifest",
    "chain",
    "cluster",
    "operator",
    "dkg",
    "sealed_share",
    "release",
    "import_contract"
  ],
  "properties": {
    "schema_version": {
      "const": "monarch-protocore-key-share-handoff/v1"
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "created_at",
        "source_ceremony_id",
        "source_ceremony_type",
        "runbook_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "source_ceremony_id": {
          "type": "string",
          "minLength": 1
        },
        "source_ceremony_type": {
          "enum": [
            "initial-dkg",
            "operator-rotation",
            "share-reseal",
            "recovery",
            "emergency-revocation"
          ]
        },
        "runbook_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ceremony_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "sha256"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/hash32"
        }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "chain_id"],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "chain_id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "operator_index", "position", "next_dkg_epoch"],
      "properties": {
        "id": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]+$"
        },
        "operator_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "position": {
          "enum": ["active", "standby"]
        },
        "next_dkg_epoch": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "address",
        "position",
        "tpm_mode",
        "pcr_quote_hash",
        "pcr_event_log_hash",
        "sealed_share_policy_hash"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "address": {
          "type": "string",
          "pattern": "^(mono1[0-9a-z]+|0x[0-9a-fA-F]{40})$"
        },
        "position": {
          "enum": ["active", "standby"]
        },
        "tpm_mode": {
          "enum": ["hardware-tpm2", "vtpm-testnet"]
        },
        "pcr_quote_hash": {
          "$ref": "#/$defs/hash32"
        },
        "pcr_event_log_hash": {
          "$ref": "#/$defs/hash32"
        },
        "sealed_share_policy_hash": {
          "$ref": "#/$defs/hash32"
        }
      }
    },
    "dkg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threshold_scheme",
        "transcript_source_file",
        "transcript_import_file",
        "transcript_sha256",
        "transcript_commitment_hash",
        "participant_commitments_hash",
        "encrypted_share_bundle_hash",
        "group_public_key_hex"
      ],
      "properties": {
        "threshold_scheme": {
          "const": "ML-DSA-65-bitmap-multisig"
        },
        "transcript_source_file": {
          "$ref": "#/$defs/protocore_secret_path"
        },
        "transcript_import_file": {
          "$ref": "#/$defs/protocore_secret_path"
        },
        "transcript_sha256": {
          "$ref": "#/$defs/hash32"
        },
        "transcript_commitment_hash": {
          "$ref": "#/$defs/hash32"
        },
        "participant_commitments_hash": {
          "$ref": "#/$defs/hash32"
        },
        "encrypted_share_bundle_hash": {
          "$ref": "#/$defs/hash32"
        },
        "group_public_key_hex": {
          "type": "string",
          "pattern": "^(0x)?[0-9a-fA-F]{3904}$"
        }
      }
    },
    "sealed_share": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "import_file",
        "sha256",
        "sealed_to_tpm",
        "tpm_mode",
        "pcr_quote_hash",
        "pcr_event_log_hash",
        "sealed_share_policy_hash",
        "dkg_transcript_hash",
        "dkg_epoch"
      ],
      "properties": {
        "source_file": {
          "$ref": "#/$defs/protocore_secret_path"
        },
        "import_file": {
          "$ref": "#/$defs/protocore_secret_path"
        },
        "sha256": {
          "$ref": "#/$defs/hash32"
        },
        "sealed_to_tpm": {
          "const": true
        },
        "tpm_mode": {
          "enum": ["hardware-tpm2", "vtpm-testnet"]
        },
        "pcr_quote_hash": {
          "$ref": "#/$defs/hash32"
        },
        "pcr_event_log_hash": {
          "$ref": "#/$defs/hash32"
        },
        "sealed_share_policy_hash": {
          "$ref": "#/$defs/hash32"
        },
        "dkg_transcript_hash": {
          "$ref": "#/$defs/hash32"
        },
        "dkg_epoch": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_sha256", "protocore_digest"],
      "properties": {
        "metadata_sha256": {
          "$ref": "#/$defs/hash32"
        },
        "protocore_digest": {
          "$ref": "#/$defs/hash32"
        }
      }
    },
    "import_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "file_mode", "required_env"],
      "properties": {
        "service": {
          "const": "ext-protocore"
        },
        "file_mode": {
          "type": "string",
          "pattern": "^0?[0-7]{3}$"
        },
        "required_env": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "PROTOCORE_REQUIRE_TPM_BINDING",
            "PROTOCORE_TPM_SEALED_BLS_SHARE_FILE",
            "PROTOCORE_DKG_TRANSCRIPT_FILE"
          ],
          "properties": {
            "PROTOCORE_REQUIRE_TPM_BINDING": {
              "const": "true"
            },
            "PROTOCORE_TPM_SEALED_BLS_SHARE_FILE": {
              "$ref": "#/$defs/protocore_secret_path"
            },
            "PROTOCORE_DKG_TRANSCRIPT_FILE": {
              "$ref": "#/$defs/protocore_secret_path"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^(0x)?[0-9a-fA-F]{64}$"
    },
    "protocore_secret_path": {
      "type": "string",
      "pattern": "^/var/lib/protocore/secrets/.+"
    }
  }
}
